# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://curalink_user:<YOUR_PASSWORD>@cluster0.as4spf7.mongodb.net/curalink

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=curalink_super_secure_jwt_key_2026_project
JWT_EXPIRES_IN=7d

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<YOUR_GOOGLE_CLIENT_SECRET>
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── LLM: Groq (primary) ──────────────────────────────────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=<YOUR_GROQ_API_KEY>
GROQ_MODEL=llama-3.3-70b-versatile

# ── LLM: Ollama (fallback) ───────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── External APIs ────────────────────────────────────────────────────────────
# PubMed — no key needed for basic use, but add for higher rate limits
PUBMED_API_KEY=
# OpenAlex — polite pool: add email for higher rate limits
OPENALEX_EMAIL=manvikms318@gmail.com
# ClinicalTrials.gov — no key needed
